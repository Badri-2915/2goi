# Database (Supabase PostgreSQL via session pooler)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-1-region.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.xxxxx:password@aws-1-region.pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379/0

# App (single-domain: frontend + API + redirects all on same domain)
BASE_URL=https://2goi.in
FRONTEND_URL=https://2goi.in
ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_ANON=100
RATE_LIMIT_AUTH=1000

# CORS
CORS_ORIGINS=https://2goi.in
